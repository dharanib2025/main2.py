from flask import Flask, render_template, request
from tensorflow.keras.models import load_model
from tensorflow.keras.preprocessing import image
import numpy as np
import os

app = Flask(__name__)

# Load your trained model
model = load_model("food_model.h5")

# Update this according to your actual training class indices
# Check train_data.class_indices from training script
class_indices = {'bad': 0, 'good': 1}
# Map number back to label
label_map = {v: k for k, v in class_indices.items()}

@app.route("/", methods=["GET", "POST"])
def index():
    if request.method == "POST":
        if 'file' not in request.files:
            return "No file part"
        f = request.files['file']
        if f.filename == "":
            return "No selected file"

        # Save uploaded image to static/
        if not os.path.exists("static"):
            os.makedirs("static")
        filepath = os.path.join("static", f.filename)
        f.save(filepath)

        try:
            # Preprocess image
            img = image.load_img(filepath, target_size=(224, 224))
            img_array = image.img_to_array(img) / 255.0
            img_array = np.expand_dims(img_array, axis=0)

            # Predict
            pred = model.predict(img_array)
            print("Raw model output:", pred)  # Debug: see what model returns
            pred_class = int(round(pred[0][0]))  # Convert sigmoid output to 0 or 1
            result = label_map[pred_class].capitalize()  # Map to Good/Bad

        except Exception as e:
            return f"Error processing image: {e}"

        # Render result page
        return render_template("result.html", result=result, img_path=filepath)

    # GET request: show upload form
    return render_template("index.html")

if __name__ == "__main__":
    app.run(debug=True)
